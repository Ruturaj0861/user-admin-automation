<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="User Admin Automation Framework - Ruturaj Darekar" parallel="tests" thread-count="2">

    <test name="Chrome Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="tests.registerTests.RegisterUsersTest"/>
            <class name="tests.loginTests.LoginTest"/>
            <class name="tests.dashboardTests.DashboardActionsTest"/>
            <class name="tests.regressionTests.RegressionE2ETest"/>
        </classes>
    </test>

    <test name="Firefox Tests">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="tests.registerTests.RegisterUsersTest"/>
            <class name="tests.loginTests.LoginTest"/>
            <class name="tests.dashboardTests.DashboardActionsTest"/>
            <class name="tests.regressionTests.RegressionE2ETest"/>
        </classes>
    </test>

</suite>